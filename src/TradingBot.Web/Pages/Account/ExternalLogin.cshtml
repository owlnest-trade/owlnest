@page
@model TradingBot.Web.Pages.Account.ExternalLoginModel
@{
    ViewData["Title"] = "Signup closed";
}

<div style="max-width: 560px; margin: 40px auto;">
    <div class="card">
        <h1>Public signup is closed</h1>
        <p class="dim">
            Google sign-in is available for existing accounts only. New managed instances and
            maintainer access are handled manually.
        </p>
        <p>
            <a asp-page="/Contact" class="btn">Contact us</a>
            <a asp-page="/Account/Login" class="btn muted" style="margin-left: 10px">Back to login</a>
        </p>
    </div>
</div>
