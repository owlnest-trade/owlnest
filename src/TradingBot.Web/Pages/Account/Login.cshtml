@page
@using Microsoft.AspNetCore.Authentication
@inject IAuthenticationSchemeProvider Schemes
@model TradingBot.Web.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log in";
    var externalSchemes = (await Schemes.GetAllSchemesAsync())
        .Where(s => !string.IsNullOrEmpty(s.DisplayName))
        .ToList();
}

<div style="max-width: 460px; margin: 40px auto;">
    <div class="card">
        <h1>Log in to owlnest</h1>

        @if (Model.EmailUnknown)
        {
            <div class="errors" style="margin-bottom: 14px">
                <ul><li>No account found for <strong>@Model.Input.Email</strong>.</li></ul>
            </div>
            <p style="color: var(--muted); font-size: 13px; line-height: 1.6">
                Public signup is closed. If you need managed-instance access or maintainer access,
                use the <a asp-page="/Contact">contact form</a>.
            </p>
            <p style="margin-top: 18px">
                <a asp-page="/Account/Login">&larr; Use a different email</a>
            </p>
        }
        else if (Model.EmailKnown)
        {
            <p class="dim" style="margin-bottom: 14px">
                Signing in as <strong>@Model.Input.Email</strong>.
                <a asp-page="/Account/Login" style="margin-left: 6px">Not you?</a>
            </p>

            @if (externalSchemes.Count > 0)
            {
                <form asp-page="/Account/ExternalLogin" asp-page-handler="External" method="post" style="margin-bottom: 16px">
                    @foreach (var scheme in externalSchemes)
                    {
                        <button type="submit" name="provider" value="@scheme.Name" class="oauth-btn">
                            @if (scheme.Name == "Google")
                            {
                                <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg" style="vertical-align: middle; margin-right: 10px">
                                    <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z"/>
                                    <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18z"/>
                                    <path fill="#FBBC05" d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z"/>
                                    <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z"/>
                                </svg>
                            }
                            Sign in with @scheme.DisplayName
                        </button>
                    }
                </form>
                <div class="oauth-divider"><span>or with password</span></div>
            }

            <form method="post" asp-page-handler="SignIn">
                <div asp-validation-summary="All" class="errors"></div>
                <input type="hidden" asp-for="Input.Email" />
                <div class="field">
                    <label asp-for="Input.Password">Password</label>
                    <input asp-for="Input.Password" type="password" autocomplete="current-password" autofocus />
                </div>
                <button type="submit">Log in</button>
            </form>
        }
        else
        {
            <p class="dim" style="margin-bottom: 14px">Enter your email to continue.</p>
            <form method="post" asp-page-handler="CheckEmail">
                <div asp-validation-summary="All" class="errors"></div>
                <div class="field">
                    <label asp-for="Input.Email">Email</label>
                    <input asp-for="Input.Email" type="email" autocomplete="email" autofocus />
                </div>
                <button type="submit">Continue</button>
            </form>
            <p style="margin-top: 18px; color: var(--muted); font-size: 13px">
                Need a managed instance or maintainer access? <a asp-page="/Contact">Contact us</a>.
            </p>
        }
    </div>
</div>
