@page
@model TradingBot.Web.Pages.DiagnosticsModel
@{
    ViewData["Title"] = "Source diagnostics";
}

<div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;flex-wrap:wrap">
    <h1 style="margin:0">Live source diagnostics</h1>
    <span class="dim" style="font-size:13px">Proves every news source is actually reachable + returning real data</span>
    <div style="margin-left:auto;display:flex;gap:8px;align-items:center">
        <input id="ticker" value="AAPL" maxlength="6" style="width:90px;text-transform:uppercase;padding:8px 10px;background:var(--bg);color:var(--text);border:1px solid var(--border);border-radius:6px;font:inherit" />
        <button id="run" class="btn" type="button">Run all tests</button>
    </div>
</div>

<div id="run-meta" class="dim" style="font-size:13px;margin-bottom:10px">—</div>

<div id="results" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(360px,1fr));gap:14px"></div>

<style>
    .diag-card { background: var(--card); border: 1px solid var(--border); border-radius: 10px; padding: 18px; transition: border-color .2s ease; }
    .diag-card.ok { border-color: rgba(63,185,80,0.5); }
    .diag-card.fail { border-color: rgba(248,81,73,0.5); }
    .diag-card.empty { border-color: rgba(210,153,34,0.5); }
    .diag-card h3 { margin: 0 0 8px; font-size: 15px; color: var(--text); text-transform: none; letter-spacing: normal; }
    .diag-card .status { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; }
    .diag-card.ok .status { color: var(--bull); }
    .diag-card.fail .status { color: var(--bear); }
    .diag-card.empty .status { color: var(--warn); }
    .diag-card .meta { color: var(--muted); font-size: 12px; margin: 6px 0 12px; }
    .diag-card .samples { font-size: 13px; }
    .diag-card .samples .sample { padding: 6px 0; border-top: 1px dashed var(--border); }
    .diag-card .samples .sample:first-child { border-top: none; padding-top: 0; }
    .diag-card.running { opacity: 0.5; }
    .spinner { display: inline-block; width: 12px; height: 12px; border: 2px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; vertical-align: middle; }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@section Scripts {
<script>
    const esc = s => (s || '').replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));
    const $ = id => document.getElementById(id);

    function renderResults(results) {
        const container = $('results');
        container.innerHTML = '';
        for (const r of results) {
            const cls = !r.ok ? 'fail' : (r.resultCount === 0 ? 'empty' : 'ok');
            const samplesHtml = (r.samples && r.samples.length > 0)
                ? r.samples.map(s => `<div class="sample">${esc(s)}</div>`).join('')
                : '<div class="sample dim">(no sample output)</div>';
            container.insertAdjacentHTML('beforeend', `
                <div class="diag-card ${cls}">
                    <h3>${esc(r.source)}</h3>
                    <div class="status">${cls === 'ok' ? '✓ ' : (cls === 'fail' ? '✕ ' : '⚠ ')}${esc(r.status)}</div>
                    <div class="meta">${r.resultCount} result(s) · ${r.elapsedMs}ms</div>
                    <div class="samples">${samplesHtml}</div>
                </div>
            `);
        }
    }

    async function run() {
        const ticker = ($('ticker').value || 'AAPL').toUpperCase().trim();
        $('run').disabled = true;
        $('run').textContent = 'Running…';
        $('run-meta').innerHTML = `<span class="spinner"></span> Hitting every source live for <strong>${esc(ticker)}</strong>…`;
        $('results').innerHTML = '';
        const t0 = performance.now();
        try {
            const r = await fetch(`/api/diagnostics/sources?ticker=${encodeURIComponent(ticker)}`);
            if (!r.ok) {
                $('run-meta').textContent = `Error: HTTP ${r.status}`;
                return;
            }
            const data = await r.json();
            const elapsed = Math.round(performance.now() - t0);
            const passing = data.filter(x => x.ok).length;
            const empty = data.filter(x => x.ok && x.resultCount === 0).length;
            const failing = data.filter(x => !x.ok).length;
            $('run-meta').innerHTML = `Completed in <strong>${elapsed}ms</strong> total · <span style="color:var(--bull)">${passing - empty} OK</span> · <span style="color:var(--warn)">${empty} empty</span> · <span style="color:var(--bear)">${failing} failed</span>`;
            renderResults(data);
        } catch (e) {
            $('run-meta').textContent = `Error: ${e.message}`;
        } finally {
            $('run').disabled = false;
            $('run').textContent = 'Run all tests';
        }
    }

    $('run').addEventListener('click', run);
    $('ticker').addEventListener('keydown', e => { if (e.key === 'Enter') run(); });
    run();   // auto-run on page load
</script>
}
